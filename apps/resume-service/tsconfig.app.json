{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "types": ["node"],
    "rootDir": "src",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "es2021"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["**/*.spec.ts", "**/*.test.ts"],
  "references": [
    {
      "path": "../../libs/shared/constants/tsconfig.lib.json"
    },
    {
      "path": "../../libs/shared/database/tsconfig.lib.json"
    },
    {
      "path": "../../libs/shared/langchain/tsconfig.lib.json"
    }
  ]
}
